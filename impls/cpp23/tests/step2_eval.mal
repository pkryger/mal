;; Testing evaluation of single argument arithmetic operations
(+ 3)
;=>3

(- 4)
;=>-4

(* 5)
;=>5

(/ 6)
;/.+

;; Testing evaluation of multiple argument arithmetic operations
(+ 3 4 5)
;=>12

(- 4 5 6)
;=>-7

(* 5 6 7)
;=>210

(/ 42 7 3)
;=>2

;; Testing evaluation of multiple argument comparison operations
(< 3 4 5)
;=>true

(< 4 5 5)
;=>false

(< 4 4 5)
;=>false

(<= 3 4 5)
;=>true

(<= 4 5 5)
;=>true

(<= 4 4 5)
;=>true

(<= 4 4 4)
;=>true

(<= 4 5 4)
;=>false

(<= 4 3 5)
;=>false

(> 5 4 3)
;=>true

(> 5 5 4)
;=>false

(> 5 4 4)
;=>false

(>= 5 4 3)
;=>true

(>= 5 5 4)
;=>true

(>= 5 4 4)
;=>true

(>= 4 4 4)
;=>true

(>= 4 5 4)
;=>false

(>= 5 3 4)
;=>false

(= 6 6 6)
;=>true

(= 6 6 7)
;=>false

(= 7 6 6)
;=>false
