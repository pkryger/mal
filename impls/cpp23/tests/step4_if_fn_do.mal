;;
;; Testing def! in captured environments

(def! f (fn* () (do (def! a 2) a)))
(f)
;=>2
a
;/.*'?a'? not found.*

(def! f (let* [a 1] (do (def! a 2) (fn* () a))))
(f)
;=>2
a
;/.*'?a'? not found.*

(def! f (let* [a 1] (fn* () (do (def! a 2) a))))
(f)
;=>2
a
;/.*'?a'? not found.*

;; Testing long string quoting
"\"123456\"\\\n01234\n\\\"89012\\\n\"456789"
;=>"\"123456\"\\\n01234\n\\\"89012\\\n\"456789"

(pr-str "\"123456\"\\\n01234\n\\\"89012\\\n\"456789")
;=>"\"\\\"123456\\\"\\\\\\n01234\\n\\\\\\\"89012\\\\\\n\\\"456789\""

(str "\"123456\"\\\n01234\n\\\"89012\\\n\"456789")
;=>"\"123456\"\\\n01234\n\\\"89012\\\n\"456789"

(prn "\"123456\"\\\n01234\n\\\"89012\\\n\"456789")
;/"\\"123456\\"\\\\\\n01234\\n\\\\\\"89012\\\\\\n\\"456789"
;=>nil

(println "\"123456\"\\\n01234\n\\\"89012\\\n\"456789")
;/"123456"\\
;/01234
;/\\"89012\\
;/"456789
;=>nil

;; Testing DEBUG-EVAL propagation
(def! f (fn* [a] (+ a a)))

(def! DEBUG-EVAL true)
;=>true

(f 2)
;/EVAL: \(\+ a a\).*\n4

(def! DEBUG-EVAL false)
;=>false

(def! f (fn* [a] (+ a a)))

(def! DEBUG-EVAL true)
;=>true

(f 3)
;/EVAL: \(\+ a a\).*\n6
